generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


model User {
    id Int @id @default(autoincrement())
    name String 
    email String @unique
    password String  @unique
    role  role_admin @default(Admin)
    createdAt DateTime @default(now())
    updated_at DateTime @updatedAt
    isLoggedIn Boolean @default(false)
    offers Offer[]
}


model Offer {
  id              Int      @id @default(autoincrement())
  title           String
  description     String
  publicationDate DateTime
  deadlineDate    DateTime
  status          String
  userId          Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  candidates Candidate[]
  tests      Test[]
}

model Candidate {
  id                Int      @id @default(autoincrement())
  name              String
  email             String
  phone             String
  cv                String
  submissionDate    DateTime
  applicationStatus String
  offerId           Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  offer   Offer    @relation(fields: [offerId], references: [id])
  results Result[]
}

model Form {
  id        Int      @id @default(autoincrement())
  name      String
  active    Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fields FormField[]
}

model FormField {
  id        Int      @id @default(autoincrement())
  label     String
  type      String
  required  Boolean
  formId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  form Form @relation(fields: [formId], references: [id])
}

model Test {
  id        Int      @id @default(autoincrement())
  title     String
  type      String
  active    Boolean
  offerId   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offer     Offer      @relation(fields: [offerId], references: [id])
  questions Question[]
}

model Question {
  id           Int      @id @default(autoincrement())
  content      String
  questionType String
  points       Int
  testId       Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  test    Test     @relation(fields: [testId], references: [id])
  answers Answer[]
}

model Answer {
  id         Int      @id @default(autoincrement())
  content    String
  isCorrect  Boolean
  questionId Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question Question @relation(fields: [questionId], references: [id])
}

model Result {
  id          Int      @id @default(autoincrement())
  score       Float
  testDate    DateTime
  candidateId Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id])
}

enum role_admin{
    Admin
    admin
    Super_Admin
    super_admin
}